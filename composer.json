{
	"name": "smic/page-warmup",
	"type": "typo3-cms-extension",
	"description": "Page Cache Warmup",
	"license": "GPL-3.0",
	"autoload": {
		"psr-4": {
			"Smic\\PageWarmup\\": "Classes/"
		}
	},
	"require": {
		"typo3/cms-core": "^12.4 || ^13.4 || ^14.0"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^11.5",
		"typo3/cms-frontend": "^12.4 || ^13.4 || ^14.0",
		"typo3/cms-scheduler": "^12.4 || ^13.4 || ^14.0",
		"typo3/testing-framework": "^9.3"
	},
	"config": {
		"allow-plugins": {
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		}
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"test:functional": "phpunit -c .github/phpunit.functional.xml"
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "page_warmup"
		}
	}
}
